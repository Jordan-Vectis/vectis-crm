jQuery(document).ready(function(){var options=Joomla.getOptions("com_catalog");if(options){options.filters.push("query");options.filters.push("sort");options.filters.push("per_page");options.filters.push("page");options.filters.push("upcoming");options.filters.push("archive");options.filters.push("upcoming_and_archive");options.filters.push("timeframe")}var $rootWrapper=jQuery(".com_catalog__lot-search");function updateUrl(params={},url=false){if(_.isEmpty(params)&&!("URLSearchParams"in window))return;if(!url){url=window.location.href}if(url.toString().indexOf("catalog")===-1){url=window.location.origin+"/component/catalog"}if(_.has(params,"name")&&_.has(params,"value")){url=new URL(url);url.searchParams.set(params.name,params.value);return url}else{throw"Params must have name and value fields"}}function pushState(url,params={},title=false){if(!title)title=window.location.title;history.pushState(params,window.location.title,url)}function resetUrlParams(){if(_.isEmpty(options)||_.isEmpty(options.filters))return;var newUrl=removeUrlParams(options.filters);pushState(newUrl)}function removeUrlParams(params=[],url=false){if(!("URLSearchParams"in window))return;if(_.isEmpty(params))return;if(!url){url=window.location.href}if(_.isObject(params)&&_.has(params,"name")){params=[params.name]}url=new URL(url);_.each(params,function(paramName){url.searchParams.delete(_.trim(paramName))});return url}function doAjax(urlParams={}){jQuery(document).trigger("am-ajax-start");var params=_.merge(urlParams,{name:"format",value:"raw"});var xhrUrl=updateUrl(params).toString();resetEventListeners();jQuery.get(xhrUrl,function(data){var results=jQuery(".equipment__overall-container",jQuery(data));jQuery(".equipment__overall-container",$rootWrapper).html(results);jQuery(document).trigger("am-ajax-end")})}function resetEventListeners(){jQuery("#h-am-filterslist-query-btn").off("click");jQuery("#search-input, #h-search-input").off("keypress");jQuery("#h-search-timeframe, #search-timeframe-catalog").off("change")}function tooggleLoading(){$rootWrapper.toggleClass("loading")}function buildParamsFromCheckboxes($root=jQuery(document),$clickedFilter){pushState(removeUrlParams([$clickedFilter.data("type")]));let $selectedCheckboxes=jQuery("input:checked",$root);let filters=[];$selectedCheckboxes.each(function(index,$checkbox){$checkbox=jQuery($checkbox);filters.push({name:$checkbox.data("type"),value:encodeURIComponent($checkbox.attr("value"))})});return _.mapValues(_.mapValues(_.groupBy(filters,"name"),function(value){return _.reduce(Object.values(value),function(acc,filter){acc.push(filter.value);return acc},[])}),function(v){return v.join(",")})}function resetSubCategoriesFilters($rootElement=jQuery(".filters-wrapper",$rootWrapper)){jQuery("input[data-type='s_article_sub_cat_code']",$rootElement).prop("checked",false);pushState(removeUrlParams(["s_article_sub_cat_code"]))}function resetAllCategoriesFilters($rootElement=jQuery(".filters-wrapper",$rootWrapper)){jQuery("input[data-type='s_article_sub_cat_code'], input[data-type='s_article_cat_code']",$rootElement).prop("checked",false);pushState(removeUrlParams(["s_article_sub_cat_code","s_article_cat_code"]))}function getTimeframeParams(selector="#h-search-timeframe"){[name,value]=jQuery(selector).val().split("=");return{name:name,value:value}}function initEventHandlers(){const $rootFilters=jQuery(".filters-wrapper",$rootWrapper);let $inputQuery=jQuery("#search-input, #h-search-input");$inputQuery.on("input",function(){$inputQuery.val(this.value)});let $timeFrameDropdowns=jQuery("#h-search-timeframe, #search-timeframe-catalog");$timeFrameDropdowns.change(function(e){$timeFrameDropdowns.val(this.value);if($inputQuery.val()==""){return}let event=jQuery.Event("keypress");event.which=13;event.keyCode=13;params={name:"page",value:1};pushState(updateUrl(params),params);$inputQuery.trigger(event)});url=new URL(window.location.href);window.addEventListener("popstate",function(e){doAjax()});jQuery(".paginate-item a",$rootWrapper).on("click",function(e){e.preventDefault();params={name:"page",value:jQuery(this).data("page")};pushState(updateUrl(params),params);doAjax()});jQuery(".clear-filters-text a",$rootWrapper).click(function(e){e.preventDefault();jQuery(document).trigger("am-reset-filters")});jQuery("#clear_filters",$rootWrapper).click(function(e){e.preventDefault();resetAllCategoriesFilters();doAjax()});jQuery(".filter-row label",$rootFilters).click(function(e){e.stopPropagation();e.preventDefault();jQuery(this).prev("input").click()});jQuery('.category-filter input[type="checkbox"]',$rootFilters).click(function(e){let $filter=jQuery(this);if($filter.data("type")==="s_article_cat_code"){resetSubCategoriesFilters($rootFilters)}const filters=buildParamsFromCheckboxes($rootFilters,$filter);for(const filterName in filters){let params={name:filterName,value:filters[filterName]};pushState(updateUrl(params),params)}firstPageParams={name:"page",value:1};pushState(updateUrl(firstPageParams),firstPageParams);doAjax();jQuery("html, body").animate({scrollTop:0},"fast")});$querySearchButton=jQuery("#am-filterslist-query-btn, #h-am-filterslist-query-btn");$querySearchButton.click(function(){const $filter=jQuery($inputQuery);const isCatalogPage=jQuery("body").hasClass("com_catalog");if(isCatalogPage){resetAllCategoriesFilters()}var params={name:$filter.attr("name"),value:$filter.val()};if(jQuery(this).closest(".am-reset-params")){resetUrlParams()}if(isCatalogPage){pushState(updateUrl(params),params);params={name:"page",value:1};pushState(updateUrl(params),params);params=getTimeframeParams();pushState(updateUrl(params),params);doAjax()}else{let url=new URL(window.location.origin+"/catalog");location.href=updateUrl(params,updateUrl(getTimeframeParams(),url))}});$inputQuery.keypress(function(event){var keycode=event.keyCode?event.keyCode:event.which;if(keycode=="13"){var $filter=jQuery(this);const isCatalogPage=jQuery($filter).parents(".com_catalog").length>0;if(isCatalogPage){resetAllCategoriesFilters()}var params={name:$filter.attr("name"),value:$filter.val()};if(isCatalogPage){pushState(updateUrl(params),params);pushState(updateUrl(getTimeframeParams()),getTimeframeParams());doAjax()}else{location.href=updateUrl(getTimeframeParams(),updateUrl(params))}}});jQuery(".com_catalog__filters #textFilter_text-search input").keypress(function(event){var keycode=event.keyCode?event.keyCode:event.which;if(keycode=="13"){$querySearchButton.click()}});jQuery(".com_catalog #lotSorting").change(function(){var $select=jQuery(this);var params={name:$select.attr("name"),value:$select.val()};pushState(updateUrl(params),params);doAjax()});jQuery(".com_catalog__lot-search .auction-content .active-filters .close").click(function(e){e.stopPropagation();params=[jQuery(this).data("filter-name")];pushState(removeUrlParams(params));doAjax()});jQuery(".com_catalog__not-found .reset").click(function(e){e.preventDefault();jQuery(document).trigger("am-reset-filters")});jQuery("#toggle-filters",$rootWrapper).on("click",function(e){jQuery("#filters").toggle()});jQuery("#show-archived",$rootWrapper).on("click",function(e){e.preventDefault();var params={name:"archive",value:"1"};var $hiddenCheckbox=jQuery("#show-archived-checkbox");$hiddenCheckbox.prop("checked",!$hiddenCheckbox.is(":checked"));if($hiddenCheckbox.is(":checked")){document.getElementById("btn-text-change").innerHTML="Hide Past Auction Lots";pushState(updateUrl({name:"upcoming",value:1},updateUrl(params)))}else{document.getElementById("btn-text-change").innerHTML="Show Past Auction Lots";pushState(removeUrlParams(params))}doAjax()});jQuery(".go-to-page-col button",$rootWrapper).click(function(e){e.preventDefault();$pageValueInput=jQuery(this).prev();var pageNumber=parseInt($pageValueInput.val())>parseInt($pageValueInput.attr("max"))?$pageValueInput.attr("max"):$pageValueInput.val();var params={name:"page",value:pageNumber};pushState(updateUrl(params));doAjax()});jQuery("#items-per-page",$rootWrapper).change(function(e){e.preventDefault();var params={name:"per_page",value:jQuery(this).val()};pushState(updateUrl(params));params={name:"page",value:1};pushState(updateUrl(params),params);doAjax()});jQuery(".back-to-top-arrow-link").click(function(e){e.preventDefault();jQuery("html, body").animate({scrollTop:jQuery("#main-content").offset().top+"px"},"fast")});jQuery(".filter-toggler, .filters-toggler",$rootWrapper).on("click",function(e){jQuery(".auction-filters").toggleClass("filters_opened");jQuery(".filter-toggler").toggleClass("filters_opened");jQuery(".fa.fa-sliders").toggleClass("fa-times")})}jQuery(window).on("am-reset-filters",function(e){resetUrlParams();jQuery("#search-input, #h-search-input").off("keypress").val("");jQuery("#h-search-timeframe, #search-timeframe-catalog").off("change");doAjax()});jQuery(window).on("am-ajax-start",function(e){tooggleLoading()});jQuery(window).on("am-ajax-end",function(e){initEventHandlers();tooggleLoading()});initEventHandlers()});