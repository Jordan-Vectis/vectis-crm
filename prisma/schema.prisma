generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COLLECTIONS
  CATALOGUER
}

enum SubmissionChannel {
  EMAIL
  WEB_FORM
  PHONE
  WALK_IN
}

enum SubmissionStatus {
  PENDING_ASSIGNMENT
  PENDING_VALUATION
  VALUATION_COMPLETE
  PENDING_CUSTOMER_DECISION
  APPROVED
  DECLINED
  FOLLOW_UP
  COLLECTION_PENDING
  ARRIVED
  COMPLETED
}

enum LogisticsType {
  SENT_IN
  COLLECTION
}

model User {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  username       String?     @unique
  password       String
  role           Role        @default(COLLECTIONS)
  allowedApps    String[]    @default([])
  appPermissions Json?
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  assignedSubmissions Submission[] @relation("AssignedCataloguer")
  createdSubmissions  Submission[] @relation("CreatedBy")
  valuations          Valuation[]
  contactLogs         ContactLog[]
  bcToken             BCToken?
}

model BCToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  submissions Submission[]
}

model Contact {
  id           String   @id
  salutation   String?
  name         String
  email        String?
  phone        String?
  addressLine1 String?
  addressLine2 String?
  postcode     String?
  notes        String?
  isSeller     Boolean  @default(false)
  isBuyer      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  receipts        WarehouseReceipt[] @relation("ContactReceipts")
  submissions     Submission[]       @relation("ContactSubmissions")
  customerAccount CustomerAccount?
}

model CustomerAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  sessionToken String?  @unique
  contactId    String?  @unique
  contact      Contact? @relation(fields: [contactId], references: [id])

  // Shipping address
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingCounty  String?
  shippingPostcode String?

  // Billing address
  billingLine1    String?
  billingLine2    String?
  billingCity     String?
  billingCounty   String?
  billingPostcode String?
  billingSameAsShipping Boolean @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Submission {
  id             String            @id @default(cuid())
  reference      String            @unique @default(cuid())
  channel        SubmissionChannel
  status         SubmissionStatus  @default(PENDING_ASSIGNMENT)
  notes          String?
  followUpCount  Int               @default(0)
  lastFollowUpAt DateTime?

  contactId    String
  contact      Contact     @relation("ContactSubmissions", fields: [contactId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  cataloguerId String?
  cataloguer   User?       @relation("AssignedCataloguer", fields: [cataloguerId], references: [id])
  createdById  String
  createdBy    User        @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       Item[]
  contactLogs ContactLog[]
  logistics   Logistics?
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrls   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  valuation    Valuation?
}

model Valuation {
  id             String   @id @default(cuid())
  estimatedValue Float
  comments       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  itemId       String @unique
  item         Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  cataloguerId String
  cataloguer   User   @relation(fields: [cataloguerId], references: [id])
}

model ContactLog {
  id      String   @id @default(cuid())
  method  String
  notes   String?
  outcome String?
  isFollowUp Boolean @default(false)
  createdAt DateTime @default(now())

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
}

model AuctionRun {
  id        String       @id @default(cuid())
  code      String       @unique
  preset    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  lots      AuctionLot[]
}

model AuctionLot {
  id          String     @id @default(cuid())
  lot         String
  description String     @db.Text
  estimate    String
  createdAt   DateTime   @default(now())

  runId String
  run   AuctionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model AiPreset {
  key         String   @id
  instruction String   @db.Text
  updatedAt   DateTime @updatedAt
}

model Logistics {
  id      String        @id @default(cuid())
  type    LogisticsType
  arrived Boolean       @default(false)
  arrivedAt DateTime?

  collectionAddress String?
  collectionName    String?
  collectionPhone   String?
  collectionEmail   String?
  collectionNotes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model CatalogueAuction {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  auctionDate DateTime?
  auctionType String         @default("GENERAL")
  eventName   String?
  locked      Boolean        @default(false)
  finished    Boolean        @default(false)
  complete    Boolean        @default(false)
  published   Boolean        @default(false)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lots        CatalogueLot[]
  photoSessions CataloguePhotoSession[]
  liveAuction LiveAuction?
}

model LiveAuction {
  id              String           @id @default(cuid())
  auctionId       String           @unique
  auction         CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  status          String           @default("PENDING") // PENDING | ACTIVE | PAUSED | COMPLETE
  currentLotIndex Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model CatalogueLot {
  id           String           @id @default(cuid())
  lotNumber    String
  title        String
  description  String           @db.Text @default("")
  barcode      String?
  estimateLow  Int?
  estimateHigh Int?
  startingBid  Int?
  reserve      Int?
  hammerPrice  Int?
  condition    String?
  vendor       String?
  tote         String?
  receipt      String?
  category     String?
  subCategory  String?
  brand        String?
  notes        String?
  imageUrls    String[]         @default([])
  status        String           @default("ENTERED")
  createdByName String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  auctionId    String
  auction      CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
}

model CataloguePhotoSession {
  id              String           @id @default(cuid())
  auctionId       String
  auction         CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  lotBarcode      String?
  customerRef     String?
  barcodePhotoKey String?
  itemPhotoKeys   String[]         @default([])
  notes           String?
  status          String           @default("PENDING")
  createdById     String
  createdByName   String?
  createdAt       DateTime         @default(now())
}

model AppCard {
  key         String  @id
  order       Int     @default(0)
  visible     Boolean @default(true)
  pinned      Boolean @default(false)
  label       String?
  description String?
}

model BCCatalogueDay {
  date      String   @id       // "YYYY-MM-DD" — marks this date was fully fetched from BC
  fetchedAt DateTime @default(now())
}

model BCCatalogueEntry {
  date   String
  userId String
  count  Int

  @@id([date, userId])
  @@index([date])
}

model WarehouseReceipt {
  id             String   @id
  contactId      String
  contact        Contact  @relation("ContactReceipts", fields: [contactId], references: [id])
  commissionRate Float    @default(0)
  notes          String?
  status         String   @default("open")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  containers WarehouseContainer[]
}

model WarehouseContainer {
  id          String           @id
  type        String
  description String
  category    String?
  subcategory String?
  receiptId   String
  receipt     WarehouseReceipt @relation(fields: [receiptId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  movements WarehouseMovement[]
}

model WarehouseLocation {
  id        String   @id @default(cuid())
  code      String   @unique
  createdAt DateTime @default(now())

  movements WarehouseMovement[]
}

model WarehouseMovement {
  id           String             @id @default(cuid())
  containerId  String
  container    WarehouseContainer @relation(fields: [containerId], references: [id])
  locationCode String
  location     WarehouseLocation  @relation(fields: [locationCode], references: [code])
  notes        String?
  movedByName  String?
  movedAt      DateTime           @default(now())
}
